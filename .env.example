# Hugging Face
HF_TOKEN=
HF_HOME=./.cache/huggingface
# Push the trained model to this HuggingFace repo after training (leave blank to skip)
HF_PUSH_REPO_ID=BeardedMonster/gemma-3-270m-translate-it

# Policy model (causal LM; accept Gemma license on HF first)
MODEL_NAME_OR_PATH=google/gemma-3-270m-it
TRUST_REMOTE_CODE=false

# AfriCOMET reward (requires: pip install unbabel-comet)
REWARD_MODEL_ID=masakhane/africomet-stl
REWARD_BATCH_SIZE=8
REWARD_GPUS=0

# Dataset
DATASET_ID=Aletheia-ng/tds-sft
DATASET_SPLIT=train
DATASET_STREAMING=true
MAX_TRAIN_SAMPLES=50000
MAX_RL_SAMPLES=10000
SEED=42

# Paths
OUTPUT_DIR=./outputs
SFT_OUTPUT_DIR=./outputs/sft
RL_OUTPUT_DIR=./outputs/rlhf

# Prompting / generation
MAX_SOURCE_LEN=256
MAX_TARGET_LEN=256
MAX_PROMPT_LEN=512
MAX_NEW_TOKENS=128

# SFT
SFT_PER_DEVICE_BATCH_SIZE=4
SFT_GRAD_ACCUM=4
SFT_EPOCHS=1
SFT_LR=2e-5
SFT_WARMUP_RATIO=0.03
SFT_BF16=true
SFT_SAVE_STEPS=500
SFT_LOGGING_STEPS=10

# RLHF (REINFORCE-style with KL penalty; AfriCOMET reward)
RL_PER_DEVICE_BATCH_SIZE=2
RL_GRAD_ACCUM=4
RL_LEARNING_RATE=1e-5
RL_NUM_EPOCHS=1
RL_MAX_STEPS=1000
RL_KL_COEF=0.1
RL_BF16=true
RL_TEMPERATURE=0.7
RL_TOP_P=0.9
RL_REWARD_NORMALIZE=true

# PEFT (optional; full fine-tune of 270M fits on most single GPUs)
USE_LORA=false
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05

# Logging
WANDB_PROJECT=west-african-mt-rlhf
WANDB_ENABLED=false
LOG_LEVEL=INFO

# Distributed training — launch with torchrun when enabled
# Example (8 GPUs, TP=2, DP=4):  torchrun --nproc_per_node=8 scripts/run_sft.py
FSDP_ENABLED=false
FSDP_TP_SIZE=1
FSDP_SHARDING=FULL_SHARD
FSDP_CPU_OFFLOAD=false
# Auto-detected if blank (e.g. Gemma3DecoderLayer)
FSDP_TRANSFORMER_LAYER_CLS=
